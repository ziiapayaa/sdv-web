# Database
DATABASE_URL="postgresql://postgres:root@localhost:5432/societe_du_vide?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Midtrans Payment Gateway
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"

# Cleanup Cron Secret
CLEANUP_SECRET="generate-a-random-secret"

# Upstash Redis (Rate Limiting - Optional, falls back to in-memory)
# Create free Redis at https://upstash.com
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# SMTP Email (Optional - skips if not configured)
# Use Mailtrap for dev: https://mailtrap.io
# Use SendGrid/Resend/AWS SES for production
# SMTP_HOST="smtp.mailtrap.io"
# SMTP_PORT="587"
# SMTP_USER="your_smtp_user"
# SMTP_PASS="your_smtp_pass"
# SMTP_FROM="no-reply@societeduvide.com"

# Site URL (for sitemap & email links)
# NEXT_PUBLIC_SITE_URL="https://societeduvide.com"
